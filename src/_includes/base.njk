<!DOCTYPE html>
<html lang="en" class="is-loading">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#011901">
    <meta name="theme-color" content="#f3eaea" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#011901" media="(prefers-color-scheme: dark)">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default" media="(prefers-color-scheme: light)">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" media="(prefers-color-scheme: dark)">
    <meta name="description" content="The Garden Bar and Grill is an outdoor restaurant located in Lagos, Portugal, offering a unique dining experience with a focus on fresh, local ingredients and a relaxed atmosphere.">
    <script>
      (function () {
        let theme = localStorage.getItem("theme");
        if (!theme && window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
          theme = "dark";
        }
        if (theme === "dark") {
          document.documentElement.classList.add("dark-mode");
        }
      })();
    </script>
    <link rel="icon" href="/assets/logos/garden-favicon.webp" type="image/x-icon">
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/fonts/pacifico-v22-latin-regular.woff2">
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/fonts/open-sans-v43-latin-regular.woff2">
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/fonts/open-sans-v43-latin-500.woff2">
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/fonts/open-sans-v43-latin-700.woff2">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/day/garden-day-1-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/day/garden-day-1-m.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/night/garden-night-1-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/night/garden-night-1-m.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/about-bg-l.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/about-bg-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/menu-bg-l.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/menu-bg-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/gallery-bg-l.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/gallery-bg-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/contact-bg-l.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/background/contact-bg-s.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/extra/creeper.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/extra/creeper-2.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/extra/bird-image.webp">
    <link rel="preload" as="image" type="image/webp" href="/assets/images/extra/bird-image-2.webp">
    <link rel="preload" href="/css/critical.css" as="style">
    <link rel="stylesheet" href="/css/critical.css">
    <link rel="preload" href="/css/style.css" as="style">
    <link rel="stylesheet" href="/css/style.css" media="print" onload="this.media='all'">
    <link rel="preload" href="/css/dark-mode.css" as="style">
    <link rel="stylesheet" href="/css/dark-mode.css">
    <link rel="stylesheet" href="/css/glightbox.min.css">
    <script src="/js/glightbox.min.js" defer></script>
    <script src="/js/gsap.min.js" defer></script>
    <script type="module" src="/js/bundle.js" defer></script>
    <noscript>
      <link rel="stylesheet" href="/css/style.css">
    </noscript>
    <title>The Garden Bar and Grill</title>
  </head>

  <body class="{{ bodyClass }}" data-page="{{ dataPage }}">
    <div class="split-overlay split-overlay--top" aria-hidden="true"></div>
    <div class="split-overlay split-overlay--center" aria-hidden="true"></div>
    <div class="split-overlay split-overlay--bottom" aria-hidden="true"></div>

      {% include "header.njk" %}

      <main id="swup" class="main {{ mainClass }} transition-fade-main">
        {% block content %}{% endblock %}
      </main>

      {% include "decor.njk" %}
      {% include "footer.njk" %}
  </body>
</html>